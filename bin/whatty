#!/usr/bin/env sh
if ! command -v bun >/dev/null 2>&1; then
  echo "whatty requires Bun. Install it from https://bun.sh" >&2
  exit 1
fi
# Follow symlinks portably (no realpath or readlink -f needed)
SCRIPT="$0"
while [ -L "$SCRIPT" ]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
  SCRIPT="$(readlink "$SCRIPT")"
  case "$SCRIPT" in /*) ;; *) SCRIPT="$SCRIPT_DIR/$SCRIPT" ;; esac
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
exec bun "$SCRIPT_DIR/../src/index.ts" "$@"
