{
  "name": "whatty",
  "version": "0.1.1",
  "type": "module",
  "engines": {
    "node": ">=22.5.0",
    "bun": ">=1.0.0"
  },
  "bin": {
    "whatty": "bin/whatty"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.json",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts",
    "!src/**/__fixtures__/",
    "bin",
    "patches",
    "scripts/postinstall.sh",
    "tsconfig.json"
  ],
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "debug:all-media": "bash scripts/debug-all-media.sh",
    "postinstall": "sh scripts/postinstall.sh"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@opentui/core": "^0.1.0",
    "@opentui/react": "^0.1.0",
    "baileys": "7.0.0-rc13",
    "pino": "^9.6.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^19.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
