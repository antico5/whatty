+            const pn = await signalRepository.lidMapping.getPNForLID(jid);
+            return pn ? jidNormalizedUser(pn) : null;
+        }
+        const lid = await signalRepository.lidMapping.getLIDForPN(jid);
+        return lid ? jidNormalizedUser(lid) : null;
+    }
+    catch {
+        return null;
+    }
+}
