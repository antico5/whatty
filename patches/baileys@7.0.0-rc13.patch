+function decryptMessageEdit({ encPayload, encIv }, { originalSenderJid, originalMsgId, editEncKey, editorJid }) {
+    if (!encIv || encIv.length !== 12) {
+        throw new Error(`Invalid MESSAGE_EDIT IV length: expected 12, got ${encIv?.length ?? 0}`);
+    }
+    const sign = Buffer.concat([
+        Buffer.from(originalMsgId),
+        Buffer.from(originalSenderJid),
+        Buffer.from(editorJid),
+        Buffer.from('Message Edit'),
+        new Uint8Array([1])
+    ]);
+    const key0 = hmacSign(editEncKey, new Uint8Array(32), 'sha256');
+    const decKey = hmacSign(sign, key0, 'sha256');
+    const decrypted = aesDecryptGCM(encPayload, decKey, encIv, Buffer.alloc(0));
+    return proto.Message.decode(decrypted);
+}
+async function alternateAddressing(jid, signalRepository) {
